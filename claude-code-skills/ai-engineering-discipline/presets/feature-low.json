{
  "name": "feature-low",
  "task": "feature",
  "risk": "low",
  "description": "Small, low-risk feature with limited blast radius.",
  "spec": {
    "mode": "feature",
    "require_non_goals": true,
    "require_acceptance_criteria": true,
    "require_open_questions": true
  },
  "loop": {
    "runbook": "feature-slice-loop",
    "max_retries": 1,
    "human_gate": "on_verify_failure",
    "checkpoint": false
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": true,
    "require_build": false,
    "require_security_scan": false
  },
  "memory": {
    "local_memory": true,
    "mem0_write": false,
    "write_pitfalls": "only_if_failure",
    "tags": [
      "feature",
      "low-risk"
    ]
  }
}

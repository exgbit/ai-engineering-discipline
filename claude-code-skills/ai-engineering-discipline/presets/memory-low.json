{
  "name": "memory-low",
  "task": "memory",
  "risk": "low",
  "description": "Memory-only request for organizing project rules, module maps, or pitfalls.",
  "spec": {
    "mode": "memory",
    "require_acceptance_criteria": false,
    "read_existing_docs": true
  },
  "loop": {
    "runbook": "memory-loop",
    "max_retries": 1,
    "human_gate": "on_conflict",
    "checkpoint": false
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": false,
    "require_build": false,
    "require_source_consistency": true,
    "require_design_diagram": false
  },
  "memory": {
    "local_memory": true,
    "write_pitfalls": "if_evidence_exists",
    "tags": [
      "memory",
      "low-risk"
    ]
  }
}

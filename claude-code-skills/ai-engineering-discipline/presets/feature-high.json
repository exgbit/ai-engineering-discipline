{
  "name": "feature-high",
  "task": "feature",
  "risk": "high",
  "description": "High-risk feature touching critical flows, data, security, billing, permissions, or infrastructure.",
  "spec": {
    "mode": "feature",
    "require_non_goals": true,
    "require_acceptance_criteria": true,
    "require_edge_cases": true,
    "require_rollback": true,
    "require_open_questions": true
  },
  "loop": {
    "runbook": "feature-slice-loop",
    "max_retries": 1,
    "human_gate": "before_implementation_and_on_failure",
    "checkpoint": true
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": true,
    "require_build": true,
    "require_security_scan": true,
    "require_manual_validation": true
  },
  "memory": {
    "local_memory": true,
    "mem0_write": true,
    "write_pitfalls": "always_if_learning",
    "tags": [
      "feature",
      "high-risk"
    ]
  }
}

{
  "name": "verify-medium",
  "task": "verify",
  "risk": "medium",
  "description": "Verification-only request for an existing change or PR.",
  "spec": {
    "mode": "verify",
    "require_acceptance_criteria": false,
    "read_existing_spec": true
  },
  "loop": {
    "runbook": "verify-loop",
    "max_retries": 1,
    "human_gate": "on_verify_failure",
    "checkpoint": false
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": true,
    "require_build": true,
    "require_security_scan": true
  },
  "memory": {
    "local_memory": true,
    "write_pitfalls": "if_failure_pattern",
    "tags": [
      "verify",
      "medium-risk"
    ]
  }
}

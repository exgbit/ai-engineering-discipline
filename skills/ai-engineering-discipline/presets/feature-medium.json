{
  "name": "feature-medium",
  "task": "feature",
  "risk": "medium",
  "description": "Default feature preset for normal product work.",
  "spec": {
    "mode": "feature",
    "require_non_goals": true,
    "require_acceptance_criteria": true,
    "require_edge_cases": true,
    "require_open_questions": true
  },
  "loop": {
    "runbook": "feature-slice-loop",
    "max_retries": 2,
    "human_gate": "on_verify_failure",
    "checkpoint": true
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": true,
    "require_build": true,
    "require_security_scan": false,
    "require_diff_coverage": true
  },
  "memory": {
    "local_memory": true,
    "write_pitfalls": "only_if_failure",
    "tags": [
      "feature",
      "medium-risk"
    ]
  }
}

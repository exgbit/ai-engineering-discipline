{
  "name": "refactor-medium",
  "task": "refactor",
  "risk": "medium",
  "description": "Behavior-preserving refactor preset.",
  "spec": {
    "mode": "refactor",
    "require_non_goals": true,
    "require_behavior_invariants": true
  },
  "loop": {
    "runbook": "refactor-loop",
    "max_retries": 1,
    "human_gate": "before_large_diff_or_verify_failure",
    "checkpoint": true
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": true,
    "require_build": true,
    "require_regression_tests": true
  },
  "memory": {
    "local_memory": true,
    "mem0_write": false,
    "write_pitfalls": "only_if_failure",
    "tags": [
      "refactor",
      "medium-risk"
    ]
  }
}

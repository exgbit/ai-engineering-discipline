{
  "name": "docs-low",
  "task": "docs",
  "risk": "low",
  "description": "Documentation-only work with source consistency checks.",
  "spec": {
    "mode": "docs",
    "require_source_links": true,
    "require_acceptance_criteria": false
  },
  "loop": {
    "runbook": "docs-loop",
    "max_retries": 1,
    "human_gate": "on_source_conflict",
    "checkpoint": false
  },
  "verify": {
    "semgrep_config": "auto",
    "severity": "warning",
    "native_tests": false,
    "require_build": false,
    "require_link_check": true,
    "require_design_diagram": false
  },
  "memory": {
    "local_memory": true,
    "write_pitfalls": "never",
    "tags": [
      "docs",
      "low-risk"
    ]
  }
}
